# Copy to .env and fill in your keys.
# LiteLLMModel (app/main.py) uses Gemini; set GOOGLE_API_KEY (from Google AI Studio or GCP).
GOOGLE_API_KEY=

# Perplexity API key for the scoped_perplexity_search tool (app/agent_tools.py).
PERPLEXITY_API_KEY=

# Anthropic API key for the generate_deep_research_hypothesis tool (app/agent_tools.py).
ANTHROPIC_API_KEY=

# Financial Modeling Prep API key for the /news endpoint (app/server.py).
FMP_API_KEY=
